# Linear
LINEAR_API_KEY=lin_api_...
LINEAR_AGENT_USER_ID=                   # Linear user ID the daemon watches for assignments
LINEAR_TEAM_ID=                         # Team to scope issue queries
LINEAR_WEBHOOK_SECRET=                  # HMAC secret for webhook verification

# Telegram
TELEGRAM_BOT_TOKEN=123:ABC...
TELEGRAM_CHAT_ID=123456789              # Chat ID of the human operator

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=                           # GitHub org or username
GITHUB_REPO=                            # Repository name
GITHUB_WEBHOOK_SECRET=                  # HMAC secret for webhook verification

# Paths
REPO_PATH=/home/agent/repos/myproject   # Path to pre-cloned repository

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Server
WEBHOOK_PORT=3000                       # Port for Fastify webhook server
WEBHOOK_BASE_URL=https://...            # Public URL for webhook registration
